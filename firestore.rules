rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global categories, settings, transactions are no longer used but if they are read, we can block them
    // Users collection rules: only the user can read/write their own data
    match /users/{userId} {
      // User document itself
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // All subcollections inside the user's document (tasks, notes, habits, transactions, categories, settings)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
